---
import Badge from '../ui/Badge.tsx';
import Button from '../ui/Button.tsx';
---

<section class="relative w-full h-[80vh] flex items-center justify-center text-center text-white">
  <img
    src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1920"
    alt="Estudiante de oposiciones trabajando"
    class="absolute inset-0 w-full h-full object-cover"
  />
  <div class="absolute inset-0 bg-black/60 z-10" />
  <div class="relative z-20 container px-4 md:px-6 mx-auto">
    <div class="flex flex-col justify-center items-center space-y-6">
      <div class="space-y-4">
        <Badge className="text-lg bg-yellow-400 text-black hover:bg-yellow-400/90">
          Exclusivo para opositores en Canarias
        </Badge>
        <h1 class="text-4xl font-bold tracking-tighter sm:text-5xl xl:text-6xl/none font-headline">
          Tu plaza de Trabajo Social en Canarias, más cerca que nunca.
        </h1>
        <p class="max-w-[700px] text-lg text-gray-200 md:text-xl mx-auto">
          Deja de perderte en temarios genéricos. Te ofrecemos la única plataforma con temario 100% canario, casos prácticos ilimitados generados por IA y una garantía de éxito única.
        </p>
      </div>
      <div class="flex flex-col gap-2 min-[400px]:flex-row justify-center">
        <a href="/register">
          <Button size="lg" className="transform transition-transform duration-300 hover:scale-105 shadow-lg hover:shadow-xl">
            Empieza tu prueba gratis de 24 horas
          </Button>
        </a>
      </div>
    </div>
  </div>
</section>

---
import AppLogo from '../AppLogo.astro';
import Button from '../ui/Button.tsx';
---

<header class="px-4 lg:px-6 h-16 flex items-center bg-card/80 backdrop-blur-sm shadow-sm sticky top-0 z-50 border-b">
  <AppLogo/>
  <nav class="ml-auto flex items-center gap-4 sm:gap-6">
    <a href="/landing-new" class="text-sm font-medium text-primary">Inicio</a>
    <a href="/que-ofrecemos" class="text-sm font-medium text-muted-foreground hover:text-primary transition-colors">Qué ofrecemos</a>
    <a href="/precios" class="text-sm font-medium text-muted-foreground hover:text-primary transition-colors">Precios</a>
    <a href="/login">
      <Button variant="outline">Iniciar Sesión</Button>
    </a>
    <a href="/register">
      <Button>Prueba Gratis</Button>
    </a>
  </nav>
</header>

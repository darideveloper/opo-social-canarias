---
// AppLogo component for Astro
---

<a href="/" class="inline-block">
  <div class="cursor-pointer p-2">
    <div class="flex items-baseline">
      <span class="font-headline text-2xl md:text-[32px] font-bold">
        <span class="text-primary">Oposocial</span>
        <span class="text-foreground px-1">Canarias</span>
      </span>
      <div 
        class="ml-1 h-3 w-5 md:h-4 md:w-6 rounded-sm border border-foreground/50"
        style="background: linear-gradient(to right, white 0%, white 33.3%, #0051A1 33.3%, #0051A1 66.6%, #FFCD00 66.6%, #FFCD00 100%)"
      ></div>
    </div>
  </div>
</a>
